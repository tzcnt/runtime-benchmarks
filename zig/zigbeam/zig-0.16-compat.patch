diff --git a/src/libs/backoff/backoff.zig b/src/libs/backoff/backoff.zig
index 533a34e..9645587 100644
--- a/src/libs/backoff/backoff.zig
+++ b/src/libs/backoff/backoff.zig
@@ -91,7 +91,12 @@ pub const Backoff = struct {
             std.Thread.yield() catch {};
         } else {
             // Phase 4: Power-saving sleep for sustained idleness
-            std.Thread.sleep(self.config.sleep_ns);
+            // (std.Thread.sleep was removed in Zig 0.16; call nanosleep directly)
+            const ts: std.os.linux.timespec = .{
+                .sec = @intCast(self.config.sleep_ns / std.time.ns_per_s),
+                .nsec = @intCast(self.config.sleep_ns % std.time.ns_per_s),
+            };
+            _ = std.os.linux.nanosleep(&ts, null);
         }
         self.count +|= 1; // Saturating add to prevent overflow
     }
